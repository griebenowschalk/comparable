# Deployed API Gateway base URL (no trailing slash), from SAM output ApiUrl
PUBLIC_API_URL=

# Cognito — same stack as the API (SAM outputs UserPoolId + UserPoolClientId)
PUBLIC_COGNITO_USER_POOL_ID=
PUBLIC_COGNITO_CLIENT_ID=

# Set to true to show API routes and env hints in the UI (default: off)
PUBLIC_DEBUG_UI=
