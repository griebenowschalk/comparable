{
  "name": "comparable",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": ["frontend"],
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx}": [
      "eslint --fix --config frontend/eslint.config.js --max-warnings 0",
      "prettier --write --config frontend/.prettierrc"
    ],
    "frontend/**/*.css": ["prettier --write --config frontend/.prettierrc"]
  }
}
